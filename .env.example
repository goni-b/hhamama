# Copy to .env.local and fill from Supabase → Project Settings → API Keys
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Publishable key (sb_publishable_...) — the modern client key.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
# (Legacy fallback — only if your project still uses the old anon JWT)
# VITE_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY

# Data provider: "supabase" (default) or "mock" for offline local dev
VITE_DATA_MODE=supabase

# Server-side only — used by scripts/migrations, NEVER exposed to the client.
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
